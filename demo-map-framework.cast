[1116.689378, "o", ":\u001b[1CAPIServerLivenessChecker\u001b[1Cprobes\u001b[1CAPI\u001b[1Cserver\u001b[1Cconnectivity\u001b[1C(5s\u001b[1Ctimeout)\r\r\n\u001b[3C-\u001b[1CStartup\u001b[1Cprobe\u001b[1Cadded\u001b[1Cto\u001b[1Cdeployment\u001b[1Cmanifest\u001b[1C(300s\u001b[1Cbudget\u001b[1Cfor\u001b[1Ccache\u001b[1Cwarmup)\r\r\n\u001b[3C-\u001b[1CTuned\u001b[1Cprobe\u001b[1Ctimings:\u001b[1Cliveness\u001b[1C30s\u001b[1Cperiod,\u001b[1Creadiness\u001b[1C10s,\u001b[1CfailureThreshold\u001b[1C3\r\r\n\u001b[3CEOF\r\r\n\u001b[3C)\"\r\r\n\u001b[3C\u001b[38;2;153;153;153mCommit\u001b[1Chealth\u001b[1Ccheck\u001b[1Cchanges\u001b[39m\r\r\n\r\r\n\u001b[1CThis\u001b[1Ccommand\u001b[1Crequires\u001b[1Capproval\r\r\n\r\r\n\u001b[1CDo\u001b[1Cyou\u001b[1Cwant\u001b[1Cto\u001b[1Cproceed?\r\r\n\u001b[1C\u001b[38;2;177;185;249mвқҜ\u001b[1C\u001b[38;2;153;153;153m1.\u001b[1C\u001b[38;2;177;185;249mYes\u001b[39m\r\r\n\u001b[3C\u001b[38;2;153;153;153m2.\u001b[1C\u001b[39mYes,\u001b[1Cand\u001b[1CdonвҖҷt\u001b[1Cask\u001b[1Cagain\u001b[1Cfor:\u001b[1Cgit\u001b[1Ccommit\u001b[1C-m\u001b[1C\"$(cat\u001b[1C<<'EOF'\r\r\n\u001b[34CAdd\u001b[1Cmeaningful\u001b[1Chealth\u001b[1Ccheck\u001b[1Cprobes\u001b[1Creplacing\u001b[1Chealthz.Ping\r\r\n\r\r\n\u001b[34CReplace\u001b[1Csimple\u001b[1Cping-based\u001b[1Chealth\u001b[1Cchecks\u001b[1Cwith\u001b[1Cproduction-grade\u001b[1Cprobes:\r\r\n\u001b[34C-\u001b[1CReadiness:\u001b[1CCacheReadinessChecker\u001b[1Cverifies\u001b[1Cinformer\u001b[1Ccaches\u001b[1Care\u001b[1Csynced\r\r\n\u001b[34C-\u001b[1CLiveness:\u001b[1CAPI"]
