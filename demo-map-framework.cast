[1187.955842, "o", "ment\u001b[1Cmanifest\u001b[1C(failureThreshold=30,\u001b[1CperiodSeconds=10\u001b[1CвҖ”\u001b[1C300s\u001b[1Cstartup\u001b[1Cbudget)\r\r\n\u001b[3C-\u001b[1CTuned\u001b[1Cprobe\u001b[1Ctimings:\u001b[1Cstartup\u001b[1Cprobe\u001b[1Chandles\u001b[1Cinit\u001b[1Cdelay,\u001b[1Cliveness\u001b[1Cperiod\u001b[1C30s,\u001b[1Creadiness\u001b[1Cperiod\u001b[1C10s\r\r\n\r\r\n\u001b[3C##\u001b[1CTest\u001b[1Cplan\r\r\n\u001b[3C-\u001b[1C[x]\u001b[1C9\u001b[1Cnew\u001b[1Cunit\u001b[1Ctests\u001b[1Cfor\u001b[1Chealth\u001b[1Cpackage\u001b[1C(3\u001b[1Creadiness\u001b[1C+\u001b[1C6\u001b[1Cliveness)\r\r\n\u001b[3C-\u001b[1C[x]\u001b[1C14\u001b[1Cexisting\u001b[1Ccontroller\u001b[1Ctests\u001b[1Cstill\u001b[1Cpass\r\r\n\u001b[3C-\u001b[1C[x]\u001b[1C`go\u001b[1Cbuild`,\u001b[1C`go\u001b[1Cvet`\u001b[1Cclean\r\r\n\u001b[3C-\u001b[1C[x]\u001b[1C`kubectl\u001b[1Capply\u001b[1C--dry-run=client`\u001b[1Cvalidates\u001b[1Cmanifest\u001b[1CYAML\r\r\n\u001b[3C-\u001b[1C[\u001b[1C]\u001b[1CVerify\u001b[1Cprobes\u001b[1Cin\u001b[1Ca\u001b[1Crunning\u001b[1Ccluster\u001b[1Cwith\u001b[1C`kubectl\u001b[1Cdescribe\u001b[1Cpod`\r\r\n\u001b[3CEOF\r\r\n\u001b[3C)\"\r\r\n\u001b[3C\u001b[38;2;153;153;153mCreate\u001b[1Cpull\u001b[1Crequest\u001b[39m\r\r\n\r\r\n\u001b[1CThis\u001b[1Ccommand\u001b[1Crequires\u001b[1Capproval\r\r\n\r\r\n\u001b[1CDo\u001b[1Cyou\u001b[1Cwant\u001b[1Cto\u001b[1Cproceed?\r\r\n\u001b[1C\u001b[38;2;177;185;249mвқҜ\u001b[1C\u001b[38;2;153;153;153m1.\u001b[1C\u001b[38;2;177;185;249mYes\u001b[39m\r\r\n\u001b[2C\u001b[38;2;153;153;153m2.\u001b[1C\u001b[39mYes,\u001b[1Cand\u001b[1C"]
