[558.807856, "o", "                                                                                 \r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153m  9 \u001b[38;2;255;255;255m                                                                                                        \u001b[39m\r\r\n\u001b[5C\u001b[48;2;34;92;43m\u001b[38;2;255;255;255m 10 +// CacheSyncer is the subset of cache.Cache needed for readiness checks.                               \u001b[39m\u001b[49m\r\r\n\u001b[5C\u001b[48;2;34;92;43m\u001b[38;2;255;255;255m 11 +type CacheSyncer interface {                                                                           \u001b[39m\u001b[49m\r\r\n\u001b[5C\u001b[48;2;34;92;43m\u001b[38;2;255;255;255m 12 +  WaitForCacheSync(ctx context.Context) bool                                                           \u001b[39m\u001b[49m\r\r\n\u001b[5C\u001b[48;2;34;92;43m\u001b[38;2;255;255;255m 13 +}                                                                                                      \u001b[39m\u001b[49m\r\r\n\u001b[5C\u001b[48;2;34;92;43m\u001b[38;2;255;255;255m 14 +                                                                                        "]
